# Copie para .env e preencha. O .env NUNCA vai pro git (ver .gitignore).

# API-Football (api-football.com / api-sports.io) — fonte de dados.
# Crie a conta e pegue a key em https://www.api-football.com/
APISPORTS_KEY=

# Se você assinou via RapidAPI em vez do api-sports.io direto, descomente:
# API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
# API_FOOTBALL_VIA_RAPIDAPI=1

# LLM (ranqueador + roteirista). Padrão: usa sua ASSINATURA via `claude -p`
# (BETSTATS_LLM_BACKEND=claude_cli) — NÃO precisa de ANTHROPIC_API_KEY e deixe a
# linha abaixo VAZIA (se houver uma key no ambiente, o `claude` usaria a API
# cobrada em vez da assinatura — o código já remove a key do subprocesso).
# BETSTATS_LLM_BACKEND=claude_cli
# BETSTATS_CLAUDE_MODEL=        # vazio = modelo padrão da assinatura

# Só preencha se trocar para o backend de API (BETSTATS_LLM_BACKEND=api):
ANTHROPIC_API_KEY=
